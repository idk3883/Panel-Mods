local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- === CONFIGURATION ===
local TRIGGER_TEXT = "is stealing your" -- The text to watch for
local KICK_MESSAGE = "\n Disconnected \n\n \ Error"

-- === 1. CREATE THE FAKE GUI ===
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "ModMenu"
ScreenGui.Parent = PlayerGui

local DupeButton = Instance.new("TextButton")
DupeButton.Name = "DupeButton"
DupeButton.Size = UDim2.new(0, 150, 0, 50)
DupeButton.Position = UDim2.new(0.5, -75, 0.9, -60) -- Bottom Center
DupeButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
DupeButton.TextColor3 = Color3.fromRGB(255, 255, 0) -- Yellow text
DupeButton.Text = "DUPE BRAINROT"
DupeButton.Font = Enum.Font.SourceSansBold
DupeButton.TextSize = 18
DupeButton.Parent = ScreenGui

-- Add a little "Modded" glow/border
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = DupeButton

local UIStroke = Instance.new("UIStroke")
UIStroke.Thickness = 2
UIStroke.Color = Color3.fromRGB(255, 215, 0)
UIStroke.Parent = DupeButton

-- Make the button do "nothing" but look clickable
DupeButton.MouseButton1Click:Connect(function()
    DupeButton.Text = "LAGGING... (WAIT)"
    task.wait(2)
    DupeButton.Text = "Lag Other Player"
end)

-- === 2. THE PROTECTION LOGIC (SAME AS BEFORE) ===
local function isAlarmPlaying()
    for _, sound in pairs(game:GetDescendants()) do
        if sound:IsA("Sound") and sound.IsPlaying then
            return true
        end
    end
    return false
end

PlayerGui.DescendantAdded:Connect(function(obj)
    task.wait(0.1)
    if obj:IsA("TextLabel") or obj:IsA("TextBox") then
        if string.find(obj.Text:lower(), TRIGGER_TEXT:lower()) then
            if isAlarmPlaying() then
                LocalPlayer:Kick(KICK_MESSAGE)
            end
        end
    end
end)

print("Modded UI Loaded. Protection Active.")
